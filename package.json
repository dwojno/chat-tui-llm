{
  "name": "chat-cli-workspace",
  "version": "1.0.0",
  "private": true,
  "license": "ISC",
  "type": "module",
  "scripts": {
    "start": "pnpm --filter chat-cli start"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "knip": "6.29.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "typescript": "6.0.3",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "knip": {
    "workspaces": {
      ".": {
        "entry": [
          "vitest.shared.ts"
        ]
      },
      "apps/cli": {
        "entry": [
          "evalite.config.ts",
          "vitest.e2e.config.ts",
          "evals/harness/infra-setup.ts",
          "evals/suites/**/*.eval.ts",
          "tests/**/*.test.{ts,tsx}",
          "tests/e2e/full/**/*.e2e.ts",
          "tests/e2e/full/**/*.e2e-full.ts",
          "tests/e2e/full/launch.ts",
          "tests/setup.ts"
        ]
      }
    }
  }
}
