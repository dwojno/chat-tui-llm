OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# MinIO / S3 (per-profile buckets for the RAG knowledge base)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PREFIX=chat-cli-

# Qdrant (per-profile collections for dense + sparse hybrid search)
QDRANT_URL=http://localhost:6333
QDRANT_SPARSE_MODEL=Qdrant/bm25

# Chunking (RAG best practices)
RAG_CHUNK_TOKENS=512
RAG_CHUNK_OVERLAP=64

# Reranking — rescore a larger fused candidate pool by true relevance and keep
# only the best, so search returns fewer, on-topic passages (not top-N regardless
# of relevance). Set RAG_RERANK_ENABLED=false for a pure RRF baseline.
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=gpt-4o-mini
RAG_RERANK_CANDIDATE_MULTIPLIER=3     # fetch limit*this candidates to rerank
RAG_RERANK_MAX_CANDIDATES=24          # absolute cap on the candidate pool
RAG_RELATIVE_CUTOFF=0.5               # drop hits below this fraction of the top relevance
RAG_SNIPPET_MAX_CHARS=1200            # per-hit snippet cap (~a full 512-token chunk)

# web_search tool — Tavily (LLM-first: clean content + optional synthesized
# answer). Without TAVILY_API_KEY the tool returns a recoverable error and the
# agent answers from its own knowledge, so offline runs and tests still work.
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# Human-in-the-loop approval gate. On by default: when running interactively the
# agent pauses for approval before flagged or low-confidence tool calls. Set this
# truthy (1/true/yes/on) to turn it off. Headless/test runs never prompt regardless.
CHAT_APPROVALS_DISABLED=

# Chat model the agent uses to answer (defaults to the app's MODEL, gpt-4o-mini)
RAG_CHAT_MODEL=gpt-4o-mini
# LLM-as-judge model for the RAGAS-style scorers (autoevals)
RAG_JUDGE_MODEL=gpt-4.1-mini

# OpenTelemetry observability (traces + metrics via the GenAI semantic
# conventions). Off unless OTEL_ENABLED is truthy. The exporter is vendor-
# neutral — the values below point at the self-hosted Langfuse in docker-compose;
# swap the endpoint/headers for LangSmith or any OTLP collector.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=chat-cli
# Langfuse OTLP endpoint (the exporter appends /v1/traces and /v1/metrics)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3000/api/public/otel
# Basic auth built from your Langfuse project keys:
#   echo -n "pk-lf-...:sk-lf-..." | base64
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64public:secret)>
# Record prompts/completions/tool payloads as span events (set false for metadata-only)
OTEL_CAPTURE_CONTENT=true
