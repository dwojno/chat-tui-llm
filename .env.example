OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# MinIO / S3 (per-profile buckets for the RAG knowledge base)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PREFIX=chat-cli-

# Qdrant (per-profile collections for dense + sparse hybrid search)
QDRANT_URL=http://localhost:6333
QDRANT_SPARSE_MODEL=Qdrant/bm25

# Chunking (RAG best practices)
RAG_CHUNK_TOKENS=512
RAG_CHUNK_OVERLAP=64
