OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# MinIO / S3 (per-profile buckets for the RAG knowledge base)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PREFIX=chat-cli-

# Qdrant (per-profile collections for dense + sparse hybrid search)
QDRANT_URL=http://localhost:6333
QDRANT_SPARSE_MODEL=Qdrant/bm25

# Chunking (RAG best practices)
RAG_CHUNK_TOKENS=512
RAG_CHUNK_OVERLAP=64

# Reranking — rescore a larger fused candidate pool by true relevance and keep
# only the best, so search returns fewer, on-topic passages (not top-N regardless
# of relevance). Set RAG_RERANK_ENABLED=false for a pure RRF baseline.
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=gpt-4o-mini
RAG_RERANK_CANDIDATE_MULTIPLIER=3     # fetch limit*this candidates to rerank
RAG_RERANK_MAX_CANDIDATES=24          # absolute cap on the candidate pool
RAG_RELATIVE_CUTOFF=0.5               # drop hits below this fraction of the top relevance
RAG_SNIPPET_MAX_CHARS=1200            # per-hit snippet cap (~a full 512-token chunk)

# Chat model the agent uses to answer (defaults to the app's MODEL, gpt-4o-mini)
RAG_CHAT_MODEL=gpt-4o-mini
# LLM-as-judge model for the RAGAS-style scorers (autoevals)
RAG_JUDGE_MODEL=gpt-4.1-mini
